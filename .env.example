# milb-fetcher 配置

# 核心关键词，逗号分隔
FETCHER_KEYWORDS=关键词1,关键词2,关键词3

# 排除关键词，逗号分隔
FETCHER_EXCLUDE_KEYWORDS=排除词1,排除词2,排除词3

# 高价值关键词，逗号分隔（用于推荐等级判定）
FETCHER_HIGH_VALUE_KEYWORDS=高价值词1,高价值词2

# 地区，逗号分隔
FETCHER_REGIONS=地区1,地区2

# 是否使用代理（true/false）
FETCHER_USE_PROXY=false

# 代理地址，FETCHER_USE_PROXY=true 时生效，格式: http://user:pass@host:port
FETCHER_PROXY=http://user:pass@host:port

# Excel 输出目录
FETCHER_OUTPUT_DIR=~/.openclaw/workspace/military-bidding
